{
    "name": "VisionCare-Integrated-Workspace",
    "dockerComposeFile": "docker-compose.yml",
    "service": "backend",
    "workspaceFolder": "/workspaces/da",
    "forwardPorts": [8080, 3000, 3001],
    "customizations": {
        "vscode": {
            "settings": {
                "java.jdt.ls.java.home": null,
                "java.configuration.runtimes": [],
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": true,
                "dbaeumer.vscode-eslint": true
            },
            "extensions": [
                "vscjava.vscode-java-pack",
                "vscjava.vscode-spring-boot-dashboard",
                "vscjava.vscode-spring-boot-tools",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "dsznajder.es7-react-js-snippets",
                "vscjava.vscode-lombok",
                "jebbs.plantuml"
            ]
        }
    },
    "postCreateCommand": "java -version && mvn -version"
}